generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id              Int      @id @default(autoincrement())
  name            String?
  email           String   @unique
  passwordHash    String
  role            String   @default("RESIDENT")
  createdAt       DateTime @default(now())
  phone           String?
  apartmentNumber String?
  expenses        expenses[]
}

model expense_categories {
  id         Int        @id @default(autoincrement())
  name       String
  icon       String?
  created_at DateTime   @default(now())
  expenses   expenses[]
}

model expenses {
  id             Int                @id @default(autoincrement())
  user_id        Int?
  building_id    Int?
  category_id    Int?
  amount         Decimal            @db.Decimal(10, 2)
  date           DateTime           @db.Date
  description    String?
  document       String?
  supplier       String?
  payment_method String?
  period         String?
  status         expense_status     @default(PENDING)
  created_at     DateTime           @default(now())
  user           users?             @relation(fields: [user_id], references: [id])
  category       expense_categories? @relation(fields: [category_id], references: [id])
  invoice_no     String?
}

model income {
  id          Int      @id @default(autoincrement())
  daire_no    String   // "1"-"18" veya "K"
  daire_type  String   // "normal" | "dublex" | "kapici"
  year        Int
  month       Int      // 1-12
  dogalgaz    Decimal  @db.Decimal(10, 2)
  aidat       Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  status      String   @default("PENDING") // PAID | PENDING | WAIVED
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([daire_no, year, month])  // her daire için ay başına tek kayıt
  @@map("income")
}

model dues {
  id          Int        @id @default(autoincrement())
  daire_no    String     @db.VarChar(10)
  daire_type  DaireType  @default(normal)
  year        Int
  month       Int
  aidat       Decimal    @db.Decimal(10, 2)
  status      DueStatus  @default(PENDING)
  created_at  DateTime   @default(now()) @db.Timestamp(0)
  updated_at  DateTime   @updatedAt @db.Timestamp(0)

  @@unique([daire_no, year, month], name: "daire_no_year_month")
  @@index([year, month])
  @@index([status])
}

enum DaireType {
  normal
  dublex
  kapici
}

enum DueStatus {
  PAID
  PENDING
  WAIVED
}

enum expense_status {
  PENDING
  PAID
  CANCELLED
}